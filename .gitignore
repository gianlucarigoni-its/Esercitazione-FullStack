# =========================
#  DIPENDENZE
# =========================
node_modules/

# =========================
#  VARIABILI D'AMBIENTE
#  NON caricare mai file .env — contengono segreti (db uri, chiavi api, ecc.)
# =========================
.env
.env.*
!.env.example

# =========================
#  BUILD FRONTEND (Angular)
# =========================
frontend/dist/
frontend/.angular/

# =========================
#  LOG
# =========================
logs/
*.log
npm-debug.log*

# =========================
#  VS CODE
#  Ignoriamo la cartella .vscode ma teniamo fuori le impostazioni
#  condivise utili (extensions.json, settings.json del workspace)
# =========================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# =========================
#  SISTEMA OPERATIVO
# =========================

# Windows
Thumbs.db
Desktop.ini

# macOS (non lo usi ma capita nei progetti condivisi)
.DS_Store

# =========================
